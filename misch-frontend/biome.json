{
  "$schema": "https://biomejs.dev/schemas/1.5.0/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.svelte",
      "src/**/*.html",
      "src/**/*.css",
      "**/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
